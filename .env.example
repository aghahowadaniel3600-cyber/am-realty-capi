# ─── Meta Conversions API ───────────────────────────────────────────────────
# Your Meta Pixel ID (already hardcoded as fallback, but override here if needed)
META_PIXEL_ID=1083894726946341

# System User Access Token from Meta Business Manager (see README for steps)
META_ACCESS_TOKEN=your_system_user_access_token_here

# ─── Server ─────────────────────────────────────────────────────────────────
# Railway injects PORT automatically — only set this for local dev
PORT=3000
